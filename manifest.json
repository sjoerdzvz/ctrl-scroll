{
  "manifest_version": 3,
  "name": "Zzinnovate: Command+Scroll Zoom",
  "version": "2.0.0",
  "description": "Smoothly zoom in and out web pages using Cmd+Scroll. Cross-platform with settings and per-site memory.",
  "homepage_url": "https://zzinnovate.io",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "src/js/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/js/content.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "src/html/options.html",
  "icons": {
    "1024": "src/assets/1024.png",
    "512": "src/assets/512.png",
    "256": "src/assets/256.png",
    "128": "src/assets/128.png",
    "64": "src/assets/64.png"
  }
}
